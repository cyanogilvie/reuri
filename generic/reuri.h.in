#include <tcl.h>
#include "idx.h"

#ifdef __cplusplus
extern "C" {
#endif

#ifdef BUILD_reuri
#undef TCL_STORAGE_CLASS
#define TCL_STORAGE_CLASS DLLEXPORT
#endif

// Must be kept in sync with reuri_part_str
enum reuri_part {
	REURI_SCHEME,
	REURI_USERINFO,
	REURI_HOST,
	REURI_HOSTTYPE,
	REURI_PORT,
	REURI_PATH,
	REURI_QUERY,
	REURI_FRAGMENT
};

enum reuri_pathtype {
	REURI_PATH_EMPTY,
	REURI_PATH_ABSOLUTE,
	REURI_PATH_ROOTLESS
};

// Must be kept in sync with reuri_hosttype_str
enum reuri_hosttype {
	REURI_HOST_NONE,
	REURI_HOST_IPV6,			// IPv6 literal address: [::1]
	REURI_HOST_IPV4,			// IPv4 literal address: 127.0.0.1
	REURI_HOST_HOSTNAME,		// hostname: localhost
	REURI_HOST_UNIX,			// unix domain socket path: /tmp/myserv.80
	REURI_HOST_SIZE				// Marker for the size of the set
};

// Must be kept in sync with reuri_encode_mode_str
enum reuri_encode_mode {
	REURI_ENCODE_QUERY,
	REURI_ENCODE_QUERYVAL,
	REURI_ENCODE_PATH,
	REURI_ENCODE_PATH2,		// More permissive, for segments other than the first relative segment (which can't include ':' to avoid confusion with the scheme)
	REURI_ENCODE_HOST,
	REURI_ENCODE_USERINFO,
	REURI_ENCODE_FRAGMENT,
	REURI_ENCODE_AWSSIG
};

enum reuri_flags {
	REURI_FLAG_NONE		= 0,
	REURI_FLAG_REQUIRED	= 2<<0,		// Without this, Get returns NULL instead of throwing an exception
};

/* Stubs exported API */

#ifdef USE_REURI_STUBS
extern const char* ReuriInitializeStubs(Tcl_Interp* interp);
#define Reuri_InitStubs(interp)	ReuriInitializeStubs((interp))
#else
#define Reuri_InitStubs(interp)	Tcl_PkgRequire((interp), "@PACKAGE_NAME@", "@PACKAGE_VERSION@", 0)
#endif

#include "reuriDecls.h"

static inline Tcl_Obj* Reuri_PercentDecodeObj(Tcl_Obj* in)
{
	Tcl_Obj*	out = NULL;
	Reuri_PercentDecode(in, &out);
	return out;
}

static inline Tcl_Obj* Reuri_PercentEncodeObj(Tcl_Interp* interp, enum reuri_encode_mode mode, Tcl_Obj* in)
{
	Tcl_Obj*	out = NULL;
	Reuri_PercentEncode(interp, mode, in, &out);
	return out;
}

EXTERN int Reuri_Init _ANSI_ARGS_((Tcl_Interp * interp));

#ifdef __cplusplus
}
#endif
